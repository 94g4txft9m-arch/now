#!/usr/bin/env bash
# Po každom lokálnom commite skúsi push na origin (aktuálna vetva).
set +e
root="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0
cd "$root" || exit 0
branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null)" || exit 0
if ! git remote get-url origin >/dev/null 2>&1; then
  exit 0
fi
if git push origin "$branch" 2>/dev/null; then
  exit 0
fi
echo "post-commit: git push origin $branch zlyhal (offline alebo treba auth). Spusti ručne." >&2
exit 0
